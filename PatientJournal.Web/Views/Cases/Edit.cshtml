@using PatientJournal.Shared.Models
@model SimulationCase
@{
    ViewData["Title"] = "Edit Case";
}
<h2>Edit Case</h2>
<form method="post">
    <div asp-validation-summary="All" class="text-danger mb-2"></div>
    @await Html.PartialAsync("_CaseForm", Model)
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
    </div>
</form>
